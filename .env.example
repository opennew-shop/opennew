# ANCF Commerce Configuration
# Copy this file to .env and adjust values for your environment.

# PostgreSQL
DATABASE_URL=postgres://ancf:ancf@localhost:5432/ancf?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# API Gateway
API_PORT=8080

# Local Agent Renderer
ANCF_API_BASE=http://127.0.0.1:8080
ANCF_AGENT_PORT=3000
# Keep 127.0.0.1 for local-only use. Set to 0.0.0.0 when another agent/container
# needs to access the renderer through an exposed port.
ANCF_AGENT_HOST=127.0.0.1

# Logging
LOG_LEVEL=info

# JWT
JWT_SECRET=change-me-in-production
